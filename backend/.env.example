# Contact API configuration.
# Copy to `.env` and fill in to enable real email delivery.
# If these are left blank, the API still runs and logs incoming messages.

# --- SMTP (e.g. Gmail with an App Password, or any provider) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password_here

# --- Where messages go / appear to come from ---
CONTACT_TO=youraddress@gmail.com
CONTACT_FROM=youraddress@gmail.com

# --- CORS: lock this to your domain in production ---
# CORS_ALLOW_ORIGIN=https://siyonamistry.com
CORS_ALLOW_ORIGIN=*

# Local dev server port (optional)
PORT=8080
