# Contact form (api/contact.ts) email configuration.
# Copy to `.env.local` for local `vercel dev`, and set the same vars in the
# Vercel dashboard (Project → Settings → Environment Variables) for production.
# If SMTP_* are left blank, the function logs incoming messages instead of emailing.

# --- SMTP (e.g. Gmail with an App Password, or any provider) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password_here

# --- Where messages go / appear to come from ---
CONTACT_TO=youraddress@gmail.com
CONTACT_FROM=youraddress@gmail.com

# --- Optional CORS lock (same-origin in production, so usually unnecessary) ---
# CORS_ALLOW_ORIGIN=https://yourdomain.com
